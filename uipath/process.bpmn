<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:uipath="http://uipath.org/schema/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_EdgionDCRisk" targetNamespace="http://bpmn.io/schema/bpmn" exporter="UiPath Studio Web (https://uipath.com)" exporterVersion="b52d90e7">
  <bpmn:process id="Process_EdgionDCRisk" name="Process" isExecutable="true">
    <bpmn:documentation>Edgion Data Centre Physical-Risk Work-up. Case TVDC01-2026-REVIEW, asset Thames Valley DC-01. Workflow evidence shows queue intake, source-pack work-up, modeled human review task, SLA retry/escalation controls, and audit decision packet. Edgion prepares review material only, not underwriting/pricing/engineering decisions.</bpmn:documentation>
    <bpmn:extensionElements>
      <uipath:migrationVersion version="15" />
      <uipath:intsvcActivityConfig version="v2" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="Start_1" name="Start">
      <bpmn:extensionElements>
        <uipath:entryPointId value="89e2846a-67c2-40c9-ad17-85e307e21441" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:scriptTask id="Task_CreateIntake" name="Create Queue Item: Risk Review" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:script><![CDATA[
const queueItem = {
  queueName: "DataCentrePhysicalRiskReview",
  reference: "TVDC01-2026-REVIEW",
  priority: "Normal",
  specificContent: {
    queueReferenceId: "TVDC01-2026-REVIEW",
    workflowState: "case_intake_created",
    assetName: "Thames Valley DC-01",
    assetType: "Data centre",
    reviewType: "Portfolio physical-risk review",
    activeScenario: "multi-hazard",
    selectedSourceCount: 5,
    humanReviewRequired: true,
    slaHours: 48,
    retryLimit: 2,
    manualOverrideAllowed: true
  }
};
return { response: queueItem };
]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Task_LoadSourcePack" name="Load Edgion Source Pack" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:script><![CDATA[
return {
  response: {
    caseRef: "TVDC01-2026-REVIEW",
    asset: "Thames Valley DC-01",
    selectedSourceCount: 5,
    sourceIds: [
      "external_physical_risk_signal",
      "screening_level_spatial_hazard_context",
      "internal_portfolio_assumption",
      "site_resilience_notes",
      "operational_continuity_context"
    ],
    status: "source_pack_loaded"
  }
};
]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Task_RunWorkup" name="Run Specialist Work-up" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:script><![CDATA[
return {
  response: {
    workupStatus: "Prepared",
    workupSummary: "Physical-risk work-up completed for Thames Valley DC-01. Key findings: flood zone B, seismic zone 1, fire suppression Novec 1230, redundant power N+1, cooling PUE 1.35. Six evidence tasks identified.",
    evidenceTaskCount: 6,
    evidenceRequestIds: ["site_asset_basis"],
    enterpriseControls: {
      queueName: "DataCentrePhysicalRiskReview",
      slaHours: 48,
      retryPolicy: { maxAttempts: 2, retryAfterHours: 24 },
      escalationPath: ["Portfolio risk lead", "Risk engineering"],
      auditEvents: ["queue_item_created", "source_pack_loaded", "specialist_workup_prepared"]
    }
  }
};
]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:exclusiveGateway id="Gw_Prepared" name="Work-up + Evidence Ready?" default="Flow_No">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:scriptTask id="Task_MarkRetry" name="Evidence Missing: Retry / Escalate" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_No</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:script><![CDATA[
return {
  response: {
    caseRef: "TVDC01-2026-REVIEW",
    workflowState: "evidence_incomplete_retry_or_escalate",
    retryPolicy: { maxAttempts: 2, retryAfterHours: 24 },
    escalationOwner: "Portfolio risk lead",
    escalationReason: "evidence_missing_after_sla",
    manualOverrideAllowed: true,
    productBoundary: "Workflow control path; not an underwriting, pricing, or site-clearance decision."
  }
};
]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:endEvent id="End_Retry" name="Retry / Escalate End">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:scriptTask id="Task_EvidenceRequest" name="Create Evidence Request + SLA" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:script><![CDATA[
return {
  response: {
    caseRef: "TVDC01-2026-REVIEW",
    asset: "Thames Valley DC-01",
    evidenceType: "site_asset_basis",
    evidenceOwner: "Thames Valley DC Facilities Team",
    requestId: "site_asset_basis",
    slaHours: 48,
    retryPolicy: { maxAttempts: 2, retryAfterHours: 24 },
    escalationOwner: "Portfolio risk lead",
    status: "evidence_requested"
  }
};
]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Task_SlaControls" name="Apply SLA / Retry Controls" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_6b</bpmn:outgoing>
      <bpmn:script><![CDATA[
return {
  response: {
    caseRef: "TVDC01-2026-REVIEW",
    openEvidenceRequestIds: ["site_asset_basis"],
    workflowState: "sla_monitoring_active",
    slaHours: 48,
    retryCount: 0,
    retryLimit: 2,
    waitRetryEscalatePath: ["wait_for_evidence", "retry_request", "escalate_to_portfolio_risk_lead"],
    manualOverrideAllowed: true,
    nextState: "human_review_task_modeled"
  }
};
]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Task_HumanReview" name="Model Human Review Task" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_6b</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:script><![CDATA[
return {
  response: {
    integrationMode: "human_task_model",
    selectedActionId: "request_site_evidence",
    reviewerNote: "Awaiting site_asset_basis evidence package from asset owner.",
    evidenceOwner: "Thames Valley DC Facilities Team",
    allowedActions: ["request_site_evidence", "refer_risk_engineering", "proceed_with_caveats"],
    caseId: "TVDC01-2026-REVIEW",
    assetName: "Thames Valley DC-01",
    workupSummary: "Physical-risk work-up completed for Thames Valley DC-01. Key findings: flood zone B, seismic zone 1, fire suppression Novec 1230, redundant power N+1, cooling PUE 1.35. Six evidence tasks identified.",
    evidenceTaskCount: 6,
    productBoundary: "Modeled human review task; not a live Action Center task in this MVP package.",
    professionalBoundary: "Edgion prepares review material only, not underwriting/pricing/engineering decisions."
  }
};
]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Task_CaptureAction" name="Capture Action + Override" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
      <bpmn:script><![CDATA[
return {
  response: {
    reviewerAction: "Waiting for Site Evidence",
    selectedActionId: "request_site_evidence",
    reviewerNote: "Awaiting site_asset_basis evidence package from asset owner.",
    evidenceOwner: "Thames Valley DC Facilities Team",
    manualOverrideRequested: false,
    openEvidenceRequestIds: ["site_asset_basis"],
    auditEvent: "reviewer_action_captured"
  }
};
]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:exclusiveGateway id="Gw_WhichAction" name="Action / Override?" default="Flow_Caveat">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_Waiting</bpmn:outgoing>
      <bpmn:outgoing>Flow_Referred</bpmn:outgoing>
      <bpmn:outgoing>Flow_Caveat</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gw_Join" name="Join Actions">
      <bpmn:incoming>Flow_Waiting</bpmn:incoming>
      <bpmn:incoming>Flow_Referred</bpmn:incoming>
      <bpmn:incoming>Flow_Caveat</bpmn:incoming>
      <bpmn:outgoing>Flow_Join</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:scriptTask id="Task_GenerateDecision" name="Generate Audit Decision Packet" scriptFormat="JavaScript">
      <bpmn:incoming>Flow_Join</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:script><![CDATA[
return {
  response: {
    recordType: "workflow_decision_packet",
    queueReferenceId: "TVDC01-2026-REVIEW",
    caseRef: "TVDC01-2026-REVIEW",
    asset: "Thames Valley DC-01",
    reviewerAction: "Waiting for Site Evidence",
    workupSummary: "Physical-risk work-up completed for Thames Valley DC-01. Key findings: flood zone B, seismic zone 1, fire suppression Novec 1230, redundant power N+1, cooling PUE 1.35. Six evidence tasks identified.",
    evidenceTaskCount: 6,
    createdEvidenceRequestIds: ["site_asset_basis"],
    payloadSections: ["queueItem", "professionalWorkup", "executionPlan", "humanTask", "decisionRecord"],
    enterpriseControls: {
      queueName: "DataCentrePhysicalRiskReview",
      slaHours: 48,
      retryPolicy: { maxAttempts: 2, retryAfterHours: 24 },
      escalationPath: ["Portfolio risk lead", "Risk engineering"],
      manualOverrideAllowed: true
    },
    reviewerNote: "Awaiting site_asset_basis evidence package from asset owner.",
    evidenceOwner: "Thames Valley DC Facilities Team",
    productBoundary: "Modeled human review task; not a live Action Center task in this MVP package.",
    professionalBoundary: "Edgion prepares review material only, not underwriting/pricing/engineering decisions.",
    generatedAt: new Date().toISOString(),
    status: "audit_packet_generated"
  }
};
]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:endEvent id="End_Main" name="Audit Packet End">
      <bpmn:incoming>Flow_9</bpmn:incoming>
    </bpmn:endEvent>
